import string

# Step 1: Use direct text instead of file
text = "Natural Language Processing is a part of Artificial Intelligence. It helps computers understand human language and process text data."

print("Original Text:\n", text)

# Step 2: Convert to lowercase
text = text.lower()
print(text)

# Step 3: Remove punctuation
text = text.translate(str.maketrans('', '', string.punctuation))

# Step 4: Tokenization
words = text.split()
print(words)
# Step 5: Stopwords
stopwords = ["is", "a", "the", "and", "to", "of", "in", "it"]

filtered_words = []

for word in words:
    if word not in stopwords:
        filtered_words.append(word)

# Output (print instead of file)
print("\nFiltered Words:\n", filtered_words)